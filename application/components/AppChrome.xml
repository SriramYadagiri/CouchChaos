<component name="AppChrome" extends="Group">
    <interface>
        <field id="title" type="string" onChange="onContentChanged" />
        <field id="subtitle" type="string" onChange="onContentChanged" />
        <field id="bodyText" type="string" onChange="onContentChanged" />
        <field id="showBackButton" type="boolean" value="false" onChange="onBackStateChanged" />
        <field id="backLabel" type="string" value="Back" onChange="onBackStateChanged" />
        <function name="setBackButtonState" />
    </interface>

    <children>
        <Rectangle id="background" width="1280" height="720" color="0x07111FFF" />
        <Rectangle id="headerBand" width="1280" height="212" color="0x0A1828FF" />
        <Rectangle id="headerDivider" translation="[0, 212]" width="1280" height="2" color="0x173B59FF" />
        <Rectangle id="headerGlow" translation="[0, 210]" width="1280" height="1" color="0x36C7F3AA" />

        <RoundedButton
            id="backButton"
            translation="[60, 34]"
            buttonWidth="190"
            buttonHeight="54"
            buttonColor="0x224563FF"
            focusedButtonColor="0x2ACBFFFF"
            textColor="0xDCEBFAFF"
            focusedTextColor="0x06111DFF"
            visible="false"
        />

        <Label id="titleLabel" translation="[90, 34]" width="860" height="56" numLines="2" wrap="true" color="0xFFFFFFFF" />
        <Label id="subtitleLabel" translation="[90, 90]" width="930" height="50" numLines="2" wrap="true" font="font:MediumBoldSystemFont" color="0xD7E3FFFF" />
        <Label id="bodyLabel" translation="[90, 144]" width="1000" height="44" numLines="2" wrap="true" color="0xAFC7DAFF" />
    </children>

    <script type="text/brightscript" uri="AppChrome.brs" />
</component>
