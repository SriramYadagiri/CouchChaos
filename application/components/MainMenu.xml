<component name="MainMenu" extends="Group">
    <children>
        <AppChrome
            id="chrome"
            title=""
            subtitle="Host from the TV. Everyone joins on their phones. Vote for minigames and keep the round moving."
            bodyText=""
            showBackButton="false"
        />


        <Poster
            id="titlePoster"
            uri="pkg:/images/title.png"
            translation="[70, 10]"
            width="300"
            height="100"
            loadWidth="600"
            loadHeight="200"
        />

        <RoundedButton
            id="singlePlayerButton"
            text="Single Player Games"
            translation="[460, 330]"
            buttonWidth="360"
            buttonHeight="82"
        />

        <RoundedButton
            id="createButton"
            text="Create Room"
            translation="[460, 430]"
            buttonWidth="360"
            buttonHeight="82"
        />


    </children>

    <interface>
        <field id="sceneManager" type="node"/>
        <function name="cleanup"/>
    </interface>

    <script type="text/brightscript" uri="MainMenu.brs"/>
</component>
