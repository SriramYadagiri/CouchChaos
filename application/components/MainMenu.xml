<component name="MainMenu" extends="Group">
    <children>
        <AppChrome
            id="chrome"
            title="Choose A Game"
            subtitle="Pick any game directly, or open Couch Chaos for the full party bundle."
            bodyText="Every multiplayer game is also available inside Couch Chaos."
            showBackButton="false"
        />

        <Poster
            id="titlePoster"
            uri="pkg:/images/title.png"
            translation="[1120, 34]"
            width="110"
            height="38"
            loadWidth="600"
            loadHeight="200"
        />

        <Rectangle id="gridPanel" translation="[50, 220]" width="1180" height="420" color="0x0E2034FF" />

        <MarkupGrid
            id="gameGrid"
            itemComponentName="MiniGameItem"
            translation="[66, 240]"
            itemSize="[272, 188]"
            itemSpacing="[12, 14]"
            numColumns="4"
            numRows="2"
            drawFocusFeedback="true"
        />

        <Label id="hintLabel" translation="[90, 658]" width="1100" height="44" horizAlign="center" text="Use the arrows to pick a game. Press OK to launch or host it." color="0xC8DAEFFF" />
    </children>

    <interface>
        <field id="sceneManager" type="node"/>
        <function name="cleanup"/>
        <function name="activate"/>
    </interface>

    <script type="text/brightscript" uri="MainMenu.brs"/>
</component>
