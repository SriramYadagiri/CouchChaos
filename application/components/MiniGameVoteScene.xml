<component name="MiniGameVoteScene" extends="Group">
    <interface>
        <field id="sceneManager" type="node" />
        <field id="roomCode" type="string" />
    </interface>

    <children>
        <Rectangle
            id="background"
            width="1280"
            height="720"
            color="0x07111FFF"
        />

        <Rectangle
            id="headerPanel"
            translation="[60, 45]"
            width="1160"
            height="190"
            color="0x12263DFF"
        />

        <Rectangle
            id="headerAccent"
            translation="[60, 45]"
            width="1160"
            height="10"
            color="0x27C2FFFF"
        />

        <Rectangle
            id="gridPanel"
            translation="[60, 255]"
            width="1160"
            height="405"
            color="0x0E2034FF"
        />

        <Label
            id="titleLabel"
            text="Vote For The Next Minigame"
            translation="[90, 78]"
            width="900"
            height="50"
            color="0xFFFFFFFF"
        />

        <Label
            id="subtitleLabel"
            text="Players vote on their phones. Move focus to preview a game."
            translation="[90, 130]"
            width="980"
            height="40"
            color="0xD7E3FFFF"
        />

        <Label
            id="descriptionLabel"
            translation="[90, 170]"
            width="1070"
            height="80"
            numLines="6"
            color="0xFFFFFFFF"
        />

        <MarkupGrid
            id="miniGameGrid"
            itemComponentName="MiniGameItem"
            translation="[95, 285]"
            itemSize="[320, 220]"
            itemSpacing="[30, 30]"
            numColumns="3"
            numRows="1"
            layoutDirection="horiz"
            drawFocusFeedback="true"
        />
    </children>

    <script type="text/brightscript" uri="MiniGameVoteScene.brs" />
</component>
