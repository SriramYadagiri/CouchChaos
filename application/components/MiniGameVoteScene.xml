<component name="MiniGameVoteScene" extends="Group">
    <interface>
        <field id="sceneManager" type="node" />
        <field id="roomCode" type="string" />
        <function name="cleanup" />
    </interface>

    <children>
        <AppChrome
            id="chrome"
            title="Vote For The Next Minigame"
            subtitle="Players vote on their phones. Move focus to preview a game."
            bodyText=""
            showBackButton="true"
            backLabel="Back To Lobby"
        />

        <Rectangle
            id="gridPanel"
            translation="[60, 210]"
            width="1160"
            height="450"
            color="0x0E2034FF"
        />

        <Rectangle
            id="timerTrack"
            translation="[90, 178]"
            width="1070"
            height="14"
            color="0x24415EFF"
            visible="false"
        />

        <Rectangle
            id="timerFill"
            translation="[90, 178]"
            width="1070"
            height="14"
            color="0x27C2FFFF"
            visible="false"
        />

        <Label
            id="wordSandwichLetters"
            translation="[90, 178]"
            width="1100"
            height="64"
            numLines="1"
            horizAlign="center"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
            visible="false"
        />

        <Timer
            id="triviaTimer"
            repeat="true"
            duration="0.1"
        />

        <MarkupGrid
            id="miniGameGrid"
            itemComponentName="MiniGameItem"
            translation="[95, 242]"
            itemSize="[320, 220]"
            itemSpacing="[30, 30]"
            numColumns="3"
            numRows="1"
            layoutDirection="horiz"
            drawFocusFeedback="true"
        />

        <RoundedButton
            id="returnVoteButton"
            text="Return To Game Vote"
            translation="[882, 620]"
            buttonWidth="300"
            buttonHeight="56"
            visible="false"
        />
    </children>

    <script type="text/brightscript" uri="MiniGameVoteScene.brs" />
</component>
