<component name="MiniGameVoteScene" extends="Group">
    <interface>
        <field id="sceneManager" type="node" />
        <field id="roomCode" type="string" />
        <field id="gameMode" type="string" value="couch_chaos" />
        <function name="cleanup" />
    </interface>

    <children>
        <AppChrome
            id="chrome"
            title="Choose The Next Party Game"
            subtitle="Players can vote on their phones, or the host can start the highlighted game."
            bodyText=""
            showBackButton="true"
            backLabel="Back To Lobby"
        />

        <Rectangle
            id="gridPanel"
            translation="[60, 228]"
            width="1160"
            height="420"
            color="0x0E2034FF"
        />

        <Rectangle
            id="timerTrack"
            translation="[90, 204]"
            width="1070"
            height="14"
            color="0x24415EFF"
            visible="false"
        />

        <Rectangle
            id="timerFill"
            translation="[90, 204]"
            width="1070"
            height="14"
            color="0x27C2FFFF"
            visible="false"
        />

        <Label
            id="wordSandwichLetters"
            translation="[90, 204]"
            width="1100"
            height="64"
            numLines="1"
            horizAlign="center"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
            visible="false"
        />

        <Timer
            id="triviaTimer"
            repeat="true"
            duration="0.1"
        />

        <MarkupGrid
            id="miniGameGrid"
            itemComponentName="MiniGameItem"
            translation="[230, 250]"
            itemSize="[400, 220]"
            itemSpacing="[30, 30]"
            numColumns="2"
            numRows="1"
           
            drawFocusFeedback="true"
        />

        <RoundedButton
            id="returnVoteButton"
            text="Return To Game Vote"
            translation="[882, 636]"
            buttonWidth="300"
            buttonHeight="56"
            visible="false"
        />
    </children>

    <script type="text/brightscript" uri="MiniGameVoteScene.brs" />
</component>
