<component name="MiniGameItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
    </interface>

    <children>
        <Rectangle
            id="shadow"
            translation="[6, 8]"
            width="320"
            height="220"
            color="0x08111DCC"
        />

        <Rectangle
            id="card"
            width="320"
            height="220"
            color="0x173049FF"
        />

        <Rectangle
            id="accent"
            width="320"
            height="10"
            color="0x27C2FFFF"
        />

        <Label
            id="titleLabel"
            translation="[20, 28]"
            width="280"
            height="40"
            numLines="2"
            wrap="true"
           
            color="0xFFFFFFFF"
        />

        <Label
            id="descriptionLabel"
            translation="[20, 55]"
            width="280"
            height="120"
            numLines="5"
            wrap="true"
           
            horizAlign="center"
            vertAlign="center"
            color="0xF4F7FBFF"
        />

        <Label
            id="voteLabel"
            translation="[20, 185]"
            width="280"
            height="30"
            numLines="2"
            wrap="true"
           
            horizAlign="center"
            color="0xD7E3FFFF"
        />

        <!--
            Voter character icons: up to 12 Poster nodes pre-created.
            MiniGameItem.brs positions and shows only as many as needed.
        -->
        <Group id="voterIconGroup" translation="[0, 0]" visible="false">
            <Poster id="voterIcon0"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon1"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon2"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon3"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon4"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon5"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon6"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon7"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon8"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon9"  width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon10" width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
            <Poster id="voterIcon11" width="28" height="28" loadDisplayMode="scaleToFit" visible="false" />
        </Group>


        <Group id="wordGuessProgressGroup" translation="[0, 0]" visible="false">
            <Rectangle id="progressTile0" width="62" height="62" color="0x203246FF" />
            <Rectangle id="progressTile1" width="62" height="62" color="0x203246FF" />
            <Rectangle id="progressTile2" width="62" height="62" color="0x203246FF" />
            <Rectangle id="progressTile3" width="62" height="62" color="0x203246FF" />
            <Rectangle id="progressTile4" width="62" height="62" color="0x203246FF" />
            <Label id="progressTileLabel0" width="62" height="62" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="progressTileLabel1" width="62" height="62" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="progressTileLabel2" width="62" height="62" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="progressTileLabel3" width="62" height="62" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="progressTileLabel4" width="62" height="62" horizAlign="center" vertAlign="center" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="progressMetaLabel" translation="[0, 70]" width="360" height="24" horizAlign="center" color="0xC8DAEFFF" />
        </Group>

    </children>

    <script type="text/brightscript" uri="MiniGameItem.brs" />
</component>
