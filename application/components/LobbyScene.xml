<component name="LobbyScene" extends="Group">
    <interface>
        <field id="roomCode" type="string" />
        <field id="sceneManager" type="node" />
        <function name="cleanup" />
    </interface>

    <children>
        <AppChrome
            id="chrome"
            title="Room Lobby"
            subtitle="Players appear on the right as they connect."
            bodyText=""
            showBackButton="true"
            backLabel="Back To Menu"
        />

        <Rectangle
            id="leftCard"
            translation="[70, 210]"
            width="340"
            height="485"
            color="0x12263DFF"
        />

        <Rectangle
            id="leftAccent"
            translation="[70, 210]"
            width="340"
            height="10"
            color="0x27C2FFFF"
        />

        <Rectangle
            id="rightCard"
            translation="[450, 210]"
            width="760"
            height="485"
            color="0x0E2034FF"
        />

        <!-- LEFT PANEL -->
        <Group
            id="leftPanel"
            translation="[100, 232]"
        >
            <Label
                id="roomCodeTitle"
                text="ROOM CODE"
                translation="[0, 0]"
                width="200"
                height="32"
                wrap="true"
                font="font:SmallBoldSystemFont"
                color="0x7FD8FFFF"
            />

            <Label
                id="roomCodeLabel"
                translation="[0, 30]"
                width="280"
                height="56"
                horizAlign="left"
                numLines="2"
                wrap="true"
                color="0xFFFFFFFF"
            />

            <Label
                id="joinHintLabel"
                text="Scan the code to join from your phone."
                translation="[0, 65]"
                width="280"
                height="72"
                numLines="2"
                wrap="true"
                color="0xC8DAEFFF"
            />

            <Rectangle
                id="qrFrame"
                translation="[0, 132]"
                width="280"
                height="220"
                color="0x0A1827FF"
            />

            <Poster
                id="qrCode"
                width="180"
                height="180"
                translation="[50, 152]"
            />

            <RoundedButton
                id="startGameButton"
                text="Start Game"
                translation="[0, 386]"
                buttonWidth="280"
                buttonHeight="64"
            />
        </Group>


        <!-- RIGHT PANEL -->
        <Group
            id="rightPanel"
            translation="[490, 240]">

            <Label
                id="playersTitle"
                text="Players In Room"
                translation="[0, 0]"
                width="260"
                height="40"
                wrap="true"
                font="font:MediumBoldSystemFont"
                color="0xFFFFFFFF"
            />

            <Label
                id="playersSubtitle"
                text="Disconnected players stay visible while they reconnect."
                translation="[0, 42]"
                width="420"
                height="56"
                wrap="true"
                color="0xC8DAEFFF"
            />

            <MarkupGrid
                id="playerGrid"
                itemComponentName="PlayerGridItem"
                translation="[0, 75]"
                itemSize="[220, 100]"
                itemSpacing="[20, 20]"
                numColumns="3"
                numRows="3"
                layoutDirection="horiz"
                drawFocusFeedback="false"
            />
        </Group>

    </children>

    <script type="text/brightscript" uri="LobbyScene.brs" />
</component>
