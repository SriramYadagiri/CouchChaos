<component name="LobbyScene" extends="Group">
    <interface>
        <field id="roomCode" type="string" />
        <field id="sceneManager" type="node" />
        <function name="cleanup" />
    </interface>

    <children>
        <Rectangle
            id="background"
            width="1280"
            height="720"
            color="0x07111FFF"
        />

        <Rectangle
            id="backBtnShadow"
            translation="[68, 42]"
            width="190"
            height="54"
            color="0x050D16CC"
        />

        <Rectangle
            id="backBtnBg"
            translation="[60, 34]"
            width="190"
            height="54"
            color="0x224563FF"
        />

        <Rectangle
            id="backBtnGlow"
            translation="[60, 34]"
            width="190"
            height="10"
            color="0x7DA8CCFF"
        />

        <Label
            id="backBtnLabel"
            text="Back To Menu"
            translation="[60, 49]"
            width="190"
            height="28"
            horizAlign="center"
            color="0xDCEBFAFF"
        />

        <Rectangle
            id="leftCard"
            translation="[70, 90]"
            width="340"
            height="560"
            color="0x12263DFF"
        />

        <Rectangle
            id="leftAccent"
            translation="[70, 90]"
            width="340"
            height="10"
            color="0x27C2FFFF"
        />

        <Rectangle
            id="rightCard"
            translation="[450, 90]"
            width="760"
            height="560"
            color="0x0E2034FF"
        />

        <!-- LEFT PANEL -->
        <Group
            id="leftPanel"
            translation="[100, 102]"
        >
            <Label
                id="roomCodeTitle"
                text="ROOM CODE"
                translation="[0, 0]"
                width="200"
                height="32"
                wrap="true"
                color="0x7FD8FFFF"
            />

            <Label
                id="roomCodeLabel"
                translation="[0, 30]"
                width="280"
                height="56"
                horizAlign="left"
                numLines="2"
                wrap="true"
                color="0xFFFFFFFF"
            />

            <Label
                id="joinHintLabel"
                text="Scan the code to join from your phone."
                translation="[0, 65]"
                width="280"
                height="52"
                numLines="2"
                wrap="true"
                color="0xC8DAEFFF"
            />

            <Rectangle
                id="qrFrame"
                translation="[0, 108]"
                width="280"
                height="246"
                color="0x0A1827FF"
            />

            <Poster
                id="qrCode"
                width="220"
                height="220"
                translation="[30, 121]"
            />

            <Label
                id="helperLabel"
                text="Players appear on the right as they connect."
                translation="[0, 360]"
                width="280"
                height="52"
                numLines="2"
                wrap="true"
                color="0xC8DAEFFF"
            />

            <Rectangle
                id="startGameBtnShadow"
                translation="[0, 410]"
                width="280"
                height="64"
                color="0x050D16CC"
            />

            <Rectangle
                id="startGameBtnBg"
                translation="[0, 394]"
                width="280"
                height="64"
                color="0x1E8FFFFF"
            />

            <Rectangle
                id="startGameBtnGlow"
                translation="[0, 394]"
                width="280"
                height="10"
                color="0x7DE3FFFF"
            />

            <Label
                id="startGameBtnLabel"
                text="Start Game"
                translation="[0, 412]"
                width="280"
                height="28"
                horizAlign="center"
                wrap="true"
                color="0x06111DFF"
            />
        </Group>


        <!-- RIGHT PANEL -->
        <Group
            id="rightPanel"
            translation="[490, 130]">

            <Label
                id="playersTitle"
                text="Players In Room"
                translation="[0, 0]"
                width="260"
                height="40"
                wrap="true"
                color="0xFFFFFFFF"
            />

            <Label
                id="playersSubtitle"
                text="Disconnected players stay visible while they reconnect."
                translation="[0, 42]"
                width="420"
                height="56"
                wrap="true"
                color="0xC8DAEFFF"
            />

            <MarkupGrid
                id="playerGrid"
                itemComponentName="PlayerGridItem"
                translation="[0, 100]"
                itemSize="[220, 100]"
                itemSpacing="[20, 20]"
                numColumns="3"
                numRows="4"
                layoutDirection="horiz"
                drawFocusFeedback="false"
            />
        </Group>

    </children>

    <script type="text/brightscript" uri="LobbyScene.brs" />
</component>
