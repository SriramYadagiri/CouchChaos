<component name="PlayerGridItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
    </interface>

    <children>
        <Rectangle id="card" width="220" height="80" color="0x173049FF" />
        <Rectangle id="accent" width="220" height="6" color="0x27C2FFFF" />
        <Poster id="characterIcon" width="40" height="40" translation="[12, 22]" loadDisplayMode="scaleToFit" visible="false" />
        <Label id="playerName" translation="[62, 12]" width="146" height="28" horizAlign="left" color="0xFFFFFFFF" />
        <Label id="statusLabel" translation="[62, 42]" width="146" height="22" horizAlign="left" color="0xBFD8EAFF" />
    </children>

    <script type="text/brightscript" uri="PlayerGridItem.brs" />
</component>
